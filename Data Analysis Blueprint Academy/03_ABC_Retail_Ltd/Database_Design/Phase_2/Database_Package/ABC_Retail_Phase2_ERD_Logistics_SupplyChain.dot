digraph DomainERD {
  graph [rankdir=LR, bgcolor="white", fontname="Arial", fontsize=11, nodesep=0.35, ranksep=0.9, pad=0.3, splines=polyline];
  node [shape=plain, fontname="Arial"];
  edge [fontname="Arial", fontsize=8, color="#667788", arrowsize=0.7];
  label="ABC Retail Phase2 ERD Logistics SupplyChain";
  labelloc="t"; fontsize=18; fontcolor="#17365D";
  "inventory.StockCountItems" [label=<
<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5" COLOR="#17365D">
