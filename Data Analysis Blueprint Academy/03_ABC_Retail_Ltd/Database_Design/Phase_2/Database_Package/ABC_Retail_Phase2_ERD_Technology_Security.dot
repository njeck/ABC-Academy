  "security.SecurityIncidents" -> "it.Systems" [label="SystemID"];
  "security.SecurityIncidents" -> "core.Branches" [label="BranchID"];
  "security.SecurityIncidents" -> "hr.Employees" [label="ReportedByEmployeeID"];
  "security.SecurityIncidents" -> "hr.Employees" [label="AssignedToEmployeeID"];
  "security.SecurityIncidents" -> "security.SecurityControls" [label="ControlID"];
}