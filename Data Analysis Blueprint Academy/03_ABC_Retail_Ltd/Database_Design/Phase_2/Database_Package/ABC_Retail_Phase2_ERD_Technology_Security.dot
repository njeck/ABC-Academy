  "security.SecurityIncidents" [label=<
<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5" COLOR="#17365D">
<TR><TD BGCOLOR="#17365D"><FONT COLOR="white"><B>security.SecurityIncidents</B></FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">IncidentID</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">IncidentNumber</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">AlertID</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">AssetID</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">SystemID</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">BranchID</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">ReportedByEmployeeID</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">AssignedToEmployeeID</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">... +15 columns</FONT></TD></TR>
</TABLE>>];
  "security.Vulnerabilities" [label=<
<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5" COLOR="#17365D">
<TR><TD BGCOLOR="#17365D"><FONT COLOR="white"><B>security.Vulnerabilities</B></FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">VulnerabilityID</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">VulnerabilityNumber</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">AssetID</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">SystemID</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">DetectedDate</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">VulnerabilityTitle</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">CVEIdentifier</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">Severity</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">... +9 columns</FONT></TD></TR>
</TABLE>>];
  "core.Branches" [label=<
<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5" COLOR="#D9A300">
<TR><TD BGCOLOR="#FFF2CC"><FONT COLOR="#1F1F1F"><B>core.Branches</B></FONT></TD></TR>
<TR><TD><FONT POINT-SIZE="9">Phase 1 reference</FONT></TD></TR>
</TABLE>>];
  "core.Departments" [label=<
<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5" COLOR="#D9A300">
<TR><TD BGCOLOR="#FFF2CC"><FONT COLOR="#1F1F1F"><B>core.Departments</B></FONT></TD></TR>
<TR><TD><FONT POINT-SIZE="9">Phase 1 reference</FONT></TD></TR>
</TABLE>>];
  "hr.Employees" [label=<
<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5" COLOR="#D9A300">
<TR><TD BGCOLOR="#FFF2CC"><FONT COLOR="#1F1F1F"><B>hr.Employees</B></FONT></TD></TR>
<TR><TD><FONT POINT-SIZE="9">Phase 1 reference</FONT></TD></TR>
</TABLE>>];
  "it.Systems" -> "core.Departments" [label="BusinessOwnerDepartmentID"];
  "it.Systems" -> "hr.Employees" [label="TechnicalOwnerEmployeeID"];
  "it.ITAssets" -> "core.Branches" [label="BranchID"];
  "it.ITAssets" -> "hr.Employees" [label="AssignedEmployeeID"];
  "it.ITAssets" -> "it.Systems" [label="SystemID"];
  "it.SystemUsers" -> "it.Systems" [label="SystemID"];
  "it.SystemUsers" -> "hr.Employees" [label="EmployeeID"];
  "it.ITSupportTickets" -> "it.ITAssets" [label="AssetID"];
  "it.ITSupportTickets" -> "it.Systems" [label="SystemID"];
  "it.ITSupportTickets" -> "hr.Employees" [label="RequesterEmployeeID"];
  "it.ITSupportTickets" -> "hr.Employees" [label="AssignedToEmployeeID"];
  "it.ITSupportTickets" -> "core.Branches" [label="BranchID"];
  "security.SecurityControls" -> "core.Departments" [label="ControlOwnerDepartmentID"];
  "security.SecurityControls" -> "hr.Employees" [label="ControlOwnerEmployeeID"];
  "security.Vulnerabilities" -> "it.ITAssets" [label="AssetID"];
  "security.Vulnerabilities" -> "it.Systems" [label="SystemID"];
  "security.Vulnerabilities" -> "hr.Employees" [label="AssignedToEmployeeID"];
  "security.SecurityAlerts" -> "it.ITAssets" [label="AssetID"];
  "security.SecurityAlerts" -> "it.SystemUsers" [label="SystemUserID"];
  "security.SecurityAlerts" -> "hr.Employees" [label="AssignedToEmployeeID"];
